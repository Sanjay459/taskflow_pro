# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# --- LLM Provider ---
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/agent_interactions.jsonl

# --- Database (conversation history + tickets + audit log) ---
# Neon PostgreSQL (production): postgresql://user:pass@host/db?sslmode=require
# SQLite (local dev): leave blank — auto-creates taskflow.db in project root
DATABASE_URL=

# --- Vector Store (Pinecone — primary) ---
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=taskflow-kb
PINECONE_ENVIRONMENT=us-east-1

# --- Vector Store (ChromaDB — local fallback) ---
DOCS_PATH=data/product_docs
VECTOR_STORE_PATH=data/vectorstore

# --- LangSmith Observability ---
# Set LANGSMITH_TRACING=true to enable run tracing in LangSmith
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=taskflow-pro-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- Slack Notifications ---
# Bot token from https://api.slack.com/apps  (OAuth scope: chat:write)
# Leave blank to disable Slack notifications.
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_ESCALATION_CHANNEL=#support-escalations

# --- Google Sheets Audit Log ---
# Share your Google Sheet with the service account email (Editor access).
# GOOGLE_SERVICE_ACCOUNT_JSON can be a file path OR the raw JSON string.
# Leave blank to disable Sheets logging.
GOOGLE_SHEETS_ID=your-google-sheet-id-here
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service_account.json
GOOGLE_SHEETS_TAB=Interactions
